{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Dev (build + serve)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Start (server only)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.mjs"],
      "port": 3000
    },
    {
      "name": "Preview (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173
    }
  ]
}
