# ============================================================
#  T-MEI — Configuração
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# Pasta onde os PDFs do DAS serão salvos
MEI_DOWNLOADS=C:\Users\SeuUsuario\Documents\MEI\downloads

# ── Email (Gmail com Senha de App) ──────────────────────────
# Para criar a senha de app: myaccount.google.com > Segurança > Senhas de app

EMAIL_REMETENTE=remetente@gmail.com
EMAIL_SENHA_APP=xxxx xxxx xxxx xxxx

# E-mail destinatário padrão (usado quando a empresa não tem e-mail próprio)
EMAIL_DESTINATARIO=destinatario@email.com
