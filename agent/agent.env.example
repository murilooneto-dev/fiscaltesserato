# Fiscal Agente — Configuração
# Copie este arquivo para agent.env e preencha os valores

# Login e senha do operador (mesmos usados no sistema Fiscal Tesserato)
LOGIN=seu_login
SENHA=sua_senha

# Endereço do servidor central (IP na rede local + porta)
# Exemplo: SERVIDOR=192.168.1.10:3000
SERVIDOR=192.168.1.10:3000

# (Opcional) Comando Python a usar — padrão: python
# PYTHON_CMD=python
