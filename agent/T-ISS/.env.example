# ============================================================
#  T-ISS — Configuração
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# Pasta onde os PDFs serão salvos
# Subpasta por empresa criada automaticamente: {DOWNLOAD_DIR}/{municipio}_{login}/
DOWNLOAD_DIR=C:\Users\SeuUsuario\Documents\ISS\downloads

# Banco de dados interno do bot (log de execuções — criado automaticamente)
ISS_DB_PATH=bot_iss.db

# ── SMTP (Gmail recomendado com Senha de App) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Use "Senha de app" do Gmail (16 chars), NÃO a senha normal da conta
# Para criar: myaccount.google.com > Segurança > Senhas de app
SMTP_USER=remetente@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

EMAIL_FROM=remetente@gmail.com

# ── Browser ────────────────────────────────────────────────────────────────────
# true = sem janela (produção) | false = abre janela (depuração)
HEADLESS=true

# ── Integração com Sistema Fiscal (opcional) ───────────────────────────────────
# Deixe em branco se não estiver usando o Fiscal Tesserato.
# FISCAL_SYSTEM_URL=http://localhost:3000
