# ============================================================
#  T-SIGA — Configuração
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# Pasta onde os arquivos baixados serão salvos
# Estrutura: {SIGA_DOWNLOADS}\{CNPJ - Razão Social}\{AAAA-MM}\arquivo.xlsx
SIGA_DOWNLOADS=C:\Users\SeuUsuario\Documents\SIGA\downloads

# Banco de dados SQLite com empresas cadastradas (criado automaticamente)
SIGA_DB_PATH=C:\Users\SeuUsuario\AppData\Roaming\SIGA\empresas.db

# Planilha Excel para importação de CNPJs (opcional)
SIGA_PLANILHA=C:\Users\SeuUsuario\Documents\SIGA\contribuintes.xlsx
SIGA_COLUNA_CNPJ=CNPJ

# URL base do SIGA (não altere se for Ceará)
SIGA_URL_BASE=https://siga.sefaz.ce.gov.br

# Caminho do Chrome (detecção automática se deixar em branco)
# SIGA_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Pasta do perfil Chrome exclusivo para o SIGA
# SIGA_CHROME_PROFILE=C:\Users\SeuUsuario\AppData\Roaming\SIGA\chrome_profile

# Porta CDP do Chrome (não altere normalmente)
SIGA_CDP_PORT=9222

# Tempo máximo para aguardar login manual (minutos)
SIGA_TIMEOUT_LOGIN_MIN=10

# Timeouts em milissegundos
SIGA_TIMEOUT_MS=90000
SIGA_TIMEOUT_RELATORIO_MS=180000

# Velocidade entre ações (ms) — aumente se o SIGA estiver lento
SIGA_VELOCIDADE_MS=400

# Pausa entre empresas (segundos)
SIGA_PAUSA_ENTRE=5

# Identidade do escritório (aparece nos logs)
SIGA_NOME_ESCRITORIO=ESCRITÓRIO
SIGA_NOME_SUBTITULO=Automação SIGA
